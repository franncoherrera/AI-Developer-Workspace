{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "build",
  "plugin": [
    "ecc-universal"
  ],
  "tools": {
    "deprati-mcp*": false,
    "figma-mcp*": false
  },
  "instructions": [
    "AGENTS.md",
    "rules/global/AGENTS.md",
    "rules/global/mandatory.md",
    "node_modules/ecc-universal/skills/coding-standards/SKILL.md",
    "node_modules/ecc-universal/skills/tdd-workflow/SKILL.md",
    "node_modules/ecc-universal/skills/security-review/SKILL.md",
    "node_modules/ecc-universal/skills/backend-patterns/SKILL.md",
    "node_modules/ecc-universal/skills/frontend-patterns/SKILL.md",
    "node_modules/ecc-universal/skills/e2e-testing/SKILL.md",
    "node_modules/ecc-universal/skills/api-design/SKILL.md",
    "node_modules/ecc-universal/skills/verification-loop/SKILL.md",
    "node_modules/ecc-universal/skills/strategic-compact/SKILL.md",
    "node_modules/ecc-universal/skills/eval-harness/SKILL.md"
  ],
  "agent": {
    "build": {
      "description": "Primary coding agent for development work",
      "mode": "primary",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true,
        "read": true
      }
    },
    "deprati": {
      "description": "Agente para trabajar en el proyecto Deprati (SAP CAP + Vue 3)",
      "prompt": "Eres un asistente especializado en el proyecto Deprati. Trabajas con SAP CAP y Vue 3.",
      "rules": [
        "rules/global/AGENTS.md",
        "rules/global/mandatory.md",
        "rules/accelerator-sap-vue/AGENTS.md"
      ],
      "tools": {
        "deprati-mcp*": true,
        "figma-mcp*": true
      }
    },
    "planner": {
      "description": "Expert planning specialist for complex features and refactoring",
      "mode": "subagent",
      "prompt": "{file:node_modules/ecc-universal/.opencode/prompts/agents/planner.txt}",
      "tools": {
        "read": true,
        "bash": true,
        "write": false,
        "edit": false
      }
    },
    "architect": {
      "description": "Software architecture specialist for system design and scalability",
      "mode": "subagent",
      "prompt": "{file:node_modules/ecc-universal/.opencode/prompts/agents/architect.txt}",
      "tools": {
        "read": true,
        "bash": true,
        "write": false,
        "edit": false
      }
    },
    "code-reviewer": {
      "description": "Code review specialist for quality, security, and maintainability",
      "mode": "subagent",
      "prompt": "{file:node_modules/ecc-universal/.opencode/prompts/agents/code-reviewer.txt}",
      "tools": {
        "read": true,
        "bash": true,
        "write": false,
        "edit": false
      }
    },
    "security-reviewer": {
      "description": "Security vulnerability detection and remediation specialist",
      "mode": "subagent",
      "prompt": "{file:node_modules/ecc-universal/.opencode/prompts/agents/security-reviewer.txt}",
      "tools": {
        "read": true,
        "bash": true,
        "write": true,
        "edit": true
      }
    },
    "tdd-guide": {
      "description": "TDD specialist enforcing write-tests-first methodology",
      "mode": "subagent",
      "prompt": "{file:node_modules/ecc-universal/.opencode/prompts/agents/tdd-guide.txt}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "build-error-resolver": {
      "description": "Build and TypeScript error resolution specialist",
      "mode": "subagent",
      "prompt": "{file:node_modules/ecc-universal/.opencode/prompts/agents/build-error-resolver.txt}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "e2e-runner": {
      "description": "E2E testing specialist using Playwright",
      "mode": "subagent",
      "prompt": "{file:node_modules/ecc-universal/.opencode/prompts/agents/e2e-runner.txt}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "doc-updater": {
      "description": "Documentation and codemap specialist",
      "mode": "subagent",
      "prompt": "{file:node_modules/ecc-universal/.opencode/prompts/agents/doc-updater.txt}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "refactor-cleaner": {
      "description": "Dead code cleanup and consolidation specialist",
      "mode": "subagent",
      "prompt": "{file:node_modules/ecc-universal/.opencode/prompts/agents/refactor-cleaner.txt}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "database-reviewer": {
      "description": "Database specialist for query optimization, schema design, and performance",
      "mode": "subagent",
      "prompt": "{file:node_modules/ecc-universal/.opencode/prompts/agents/database-reviewer.txt}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "docs-lookup": {
      "description": "Documentation specialist using Context7 MCP for API docs",
      "mode": "subagent",
      "prompt": "{file:node_modules/ecc-universal/.opencode/prompts/agents/docs-lookup.txt}",
      "tools": {
        "read": true,
        "bash": true,
        "write": false,
        "edit": false
      }
    }
  },
  "command": {
    "plan": {
      "description": "Create a detailed implementation plan for complex features",
      "template": "{file:node_modules/ecc-universal/.opencode/commands/plan.md}\n\n$ARGUMENTS",
      "agent": "planner",
      "subtask": true
    },
    "tdd": {
      "description": "Enforce TDD workflow with 80%+ test coverage",
      "template": "{file:node_modules/ecc-universal/.opencode/commands/tdd.md}\n\n$ARGUMENTS",
      "agent": "tdd-guide",
      "subtask": true
    },
    "code-review": {
      "description": "Review code for quality, security, and maintainability",
      "template": "{file:node_modules/ecc-universal/.opencode/commands/code-review.md}\n\n$ARGUMENTS",
      "agent": "code-reviewer",
      "subtask": true
    },
    "security": {
      "description": "Run comprehensive security review",
      "template": "{file:node_modules/ecc-universal/.opencode/commands/security.md}\n\n$ARGUMENTS",
      "agent": "security-reviewer",
      "subtask": true
    },
    "build-fix": {
      "description": "Fix build and TypeScript errors with minimal changes",
      "template": "{file:node_modules/ecc-universal/.opencode/commands/build-fix.md}\n\n$ARGUMENTS",
      "agent": "build-error-resolver",
      "subtask": true
    },
    "e2e": {
      "description": "Generate and run E2E tests with Playwright",
      "template": "{file:node_modules/ecc-universal/.opencode/commands/e2e.md}\n\n$ARGUMENTS",
      "agent": "e2e-runner",
      "subtask": true
    },
    "refactor-clean": {
      "description": "Remove dead code and consolidate duplicates",
      "template": "{file:node_modules/ecc-universal/.opencode/commands/refactor-clean.md}\n\n$ARGUMENTS",
      "agent": "refactor-cleaner",
      "subtask": true
    },
    "orchestrate": {
      "description": "Orchestrate multiple agents for complex tasks",
      "template": "{file:node_modules/ecc-universal/.opencode/commands/orchestrate.md}\n\n$ARGUMENTS",
      "agent": "planner",
      "subtask": true
    },
    "learn": {
      "description": "Extract patterns and learnings from session",
      "template": "{file:node_modules/ecc-universal/.opencode/commands/learn.md}\n\n$ARGUMENTS"
    },
    "checkpoint": {
      "description": "Save verification state and progress",
      "template": "{file:node_modules/ecc-universal/.opencode/commands/checkpoint.md}\n\n$ARGUMENTS"
    },
    "verify": {
      "description": "Run verification loop",
      "template": "{file:node_modules/ecc-universal/.opencode/commands/verify.md}\n\n$ARGUMENTS"
    },
    "eval": {
      "description": "Run evaluation against criteria",
      "template": "{file:node_modules/ecc-universal/.opencode/commands/eval.md}\n\n$ARGUMENTS"
    },
    "update-docs": {
      "description": "Update documentation",
      "template": "{file:node_modules/ecc-universal/.opencode/commands/update-docs.md}\n\n$ARGUMENTS",
      "agent": "doc-updater",
      "subtask": true
    },
    "update-codemaps": {
      "description": "Update codemaps",
      "template": "{file:node_modules/ecc-universal/.opencode/commands/update-codemaps.md}\n\n$ARGUMENTS",
      "agent": "doc-updater",
      "subtask": true
    },
    "test-coverage": {
      "description": "Analyze test coverage",
      "template": "{file:node_modules/ecc-universal/.opencode/commands/test-coverage.md}\n\n$ARGUMENTS",
      "agent": "tdd-guide",
      "subtask": true
    },
    "setup-pm": {
      "description": "Configure package manager",
      "template": "{file:node_modules/ecc-universal/.opencode/commands/setup-pm.md}\n\n$ARGUMENTS"
    },
    "skill-create": {
      "description": "Generate skills from git history",
      "template": "{file:node_modules/ecc-universal/.opencode/commands/skill-create.md}\n\n$ARGUMENTS"
    }
  },
  "mcp": {
    "browser": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@browsermcp/mcp"
      ],
      "enabled": true,
      "environment": {}
    },
    "deprati-mcp": {
      "type": "local",
      "command": [
        "bash",
        "-c",
        "node \"$DEPRATI_BASE_PROJECT_PATH/modules/mcp/dist/index.js\""
      ],
      "enabled": true,
      "environment": {
        "DEPRATI_MCP_SUMMARIZE": "false"
      }
    },
    "figma-mcp": {
      "type": "local",
      "command": [
        "bash",
        "-c",
        "\"$DEPRATI_BASE_PROJECT_PATH/scripts/figma-mcp.sh\""
      ],
      "enabled": true,
      "environment": {}
    },
    "filesystem": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/home/franco/Qubik/AI-Developer-Workspace"
      ],
      "enabled": true,
      "environment": {}
    },
    "obsidian": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@mauricio.wolff/mcp-obsidian",
        "/home/franco/Qubik/AI-Developer-Workspace/knowledge-base"
      ],
      "enabled": true,
      "environment": {}
    }
  }
}
